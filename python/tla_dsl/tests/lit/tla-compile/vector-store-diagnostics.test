// RUN: not %tla_compile %s -o %t 2>&1 | %filecheck %s

// CHECK: error:
// CHECK-SAME: 'tla.store' op dest !tla.tensor must be in ub address space

!gm = !tla.tensor<!tla.layout<!tla.shape<64>, !tla.stride<1>, !tla.shape<64>, row_major>, !tla.coord<0>, !tla.ptr<f32, gm, 4>>

module {
  func.func @store_to_gm_diagnostic(%dst_memref: memref<64xf32, #hivm.address_space<gm>>, %value: !tla.vector<64xf32>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %dst = tla.tensor_desc %dst_memref[%c0, %c0, %c1, %c1, %c1, %c1, %c1, %c1] : (memref<64xf32, #hivm.address_space<gm>>, index, index, index, index, index, index, index, index) -> !gm
    "tla.vec.func"() ({
      tla.store %dst, %value : !gm, !tla.vector<64xf32>
    }) : () -> ()
    return
  }
}
